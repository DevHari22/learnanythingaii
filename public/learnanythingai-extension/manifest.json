{
  "manifest_version": 3,
  "name": "LearnAnythingAI",
  "version": "1.1.0",
  "description": "Transform any YouTube tutorial into a structured AI-powered classroom with modules, lessons, quizzes, and assignments.",
  "permissions": ["activeTab", "storage", "identity"],
  "oauth2": {
    "client_id": "451555291348-i5cb3c817gqb0b63n1jc4ojdvdenumcb.apps.googleusercontent.com",
    "scopes": ["email", "profile"]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "*://*.youtube.com/*",
    "https://learnanythingai-backend-production.up.railway.app/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["mock-data.json", "fonts/*"],
      "matches": ["*://*.youtube.com/*"]
    }
  ]
}
